{
  "compilerOptions": {
    "strict": true,
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "noEmit": true,
    "declaration": true,
    "isolatedDeclarations": true
  },
  "include": ["src", "./*.config.ts"]
}
